# ============================================================
# BEAR LEAD — Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA commite o .env.local com dados reais.
# ============================================================

# Supabase — obtenha em: supabase.com > seu projeto > Settings > API
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=SEU_ANON_KEY_AQUI

# Removido: GEMINI_API_KEY (não usado no projeto)
# A IA virá via n8n/webhook — configure em: Integrações > Configurar n8n
